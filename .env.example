# ─────────────────────────────────────────────────────────────
# WHALE BOT - Environment Variables
# Copy this file to .env and fill in all values before deploying
# ─────────────────────────────────────────────────────────────

# Trading Mode: "paper" or "live"
TRADING_MODE=paper

# OKX API (required for market data; required for live trading)
OKX_API_KEY=your_okx_api_key
OKX_API_SECRET=your_okx_api_secret
OKX_PASSPHRASE=your_okx_passphrase
OKX_BASE_URL=https://www.okx.com

# Trading symbol (OKX instrument ID format)
TRADING_SYMBOL=BTC-USDT-SWAP

# Etherscan API (required for whale tracking)
ETHERSCAN_API_KEY=your_etherscan_api_key

# Optional: Dune Analytics API
DUNE_API_KEY=

# Upstash Redis (required for state persistence)
UPSTASH_REDIS_REST_URL=https://your-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token

# Telegram Alerts (required for notifications)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# Cron security: secret token to validate incoming cron requests
CRON_SECRET=change_me_to_a_random_string

# Risk management overrides (optional – defaults shown)
RISK_PER_TRADE_PCT=2
MAX_POSITION_PCT=5
PAPER_INITIAL_BALANCE=10000

# Whale address to track (comma-separated Ethereum addresses)
WHALE_WATCH_ADDRESSES=

# Whale flow window in hours
WHALE_LOOKBACK_HOURS=12

# Minimum whale transfer in USD
WHALE_MIN_TRANSFER_USD=500000
